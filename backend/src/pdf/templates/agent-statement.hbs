<!DOCTYPE html>
<html dir="rtl" lang="ar">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>كشف حساب وكيل - {{agentName}}</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        * {
            font-family: 'Tajawal', sans-serif;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        @page {
            size: A4;
            margin: 10mm;
        }

        body {
            margin: 0;
            padding: 0;
            background: white;
        }

        table {
            page-break-inside: auto;
            width: 100% !important;
            table-layout: fixed !important;
        }

        tr {
            page-break-inside: avoid;
            page-break-after: auto;
        }

        thead {
            display: table-header-group;
        }
    </style>
</head>

<body class="bg-white p-6">
    <div class="max-w-full">
        <!-- Header -->
        <header class="flex justify-between items-start border-b-2 border-blue-900 pb-4 mb-6">
            <div class="flex flex-col">
                <h1 class="text-xl font-bold text-blue-900 mb-0.5">مؤسسة ساحل الشمال للتخليص الجمركي</h1>
                <h2 class="text-sm font-medium text-gray-500 mb-2">Sahil Al-shamal For Customs Clearance</h2>
                <div class="flex gap-4 text-xs text-gray-600">
                    <span><strong class="text-blue-900">الرقم الضريبي:</strong> 310430599900003</span>
                    <span class="text-gray-300">|</span>
                    <span><strong class="text-blue-900">ترخيص رقم:</strong> 4003</span>
                </div>
            </div>
            <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center border border-slate-300">
                <span class="text-sm text-slate-400">شعار</span>
            </div>
        </header>

        <!-- Title Bar -->
        <div class="flex justify-between items-center bg-blue-50 border border-blue-100 rounded-md p-3 mb-6">
            <h2 class="text-lg font-bold text-blue-900 m-0">كشف حساب وكيل ملاحي</h2>
            <div class="text-left">
                <h2 class="text-lg font-bold text-blue-900 m-0">Agent Statement</h2>
            </div>
        </div>

        <!-- Info Grid -->
        <div class="grid grid-cols-2 gap-5 mb-6">
            <div class="bg-slate-50 p-4 rounded-md border border-slate-200 border-r-4 border-r-blue-900">
                <h3 class="text-sm font-bold text-blue-900 mb-2 pb-1 border-b border-gray-300">بيانات الوكيل</h3>
                <div class="mb-1.5 text-[13px]">
                    <span class="text-gray-500">الاسم: </span>
                    <span class="font-bold text-gray-900">{{agentName}}</span>
                </div>
                <div class="mb-1.5 text-[13px]">
                    <span class="text-gray-500">الرقم الضريبي: </span>
                    <span class="font-bold text-gray-900">-</span>
                </div>
            </div>
            <div class="bg-slate-50 p-4 rounded-md border border-slate-200 border-r-4 border-r-blue-900">
                <h3 class="text-sm font-bold text-blue-900 mb-2 pb-1 border-b border-gray-300">فترة الكشف</h3>
                <div class="mb-1.5 text-[13px]">
                    <span class="text-gray-500">من: </span>
                    <span class="font-bold text-gray-900">{{startDate}}</span>
                </div>
                <div class="mb-1.5 text-[13px]">
                    <span class="text-gray-500">إلى: </span>
                    <span class="font-bold text-gray-900">{{endDate}}</span>
                </div>
            </div>
        </div>

        <!-- Transactions Table -->
        <div class="overflow-hidden rounded border border-gray-200 mb-5">
            <table class="w-full text-sm border-collapse">
                <thead class="bg-blue-900 text-white">
                    <tr>
                        <th class="py-1 px-0.5 text-center font-medium text-xs">التاريخ</th>
                        <th class="py-1 px-1 text-center font-medium text-xs">البيــــــــــــــــــــــان</th>
                        <th class="py-1 px-0.5 text-center font-medium whitespace-nowrap text-xs">عدد الشاحنات</th>
                        <th class="py-1 px-0.5 text-center font-bold text-xs">دائن</th>
                        <th class="py-1 px-0.5 text-center font-bold text-xs">مدين</th>
                        <th class="py-1 px-0.5 text-center font-bold text-xs">الرصيد</th>
                    </tr>
                </thead>
                <tbody class="text-gray-800">
                    {{#each transactions}}
                    <tr class="border-b border-gray-200 even:bg-slate-50 hover:bg-gray-50">
                        <td class="py-1 px-0.5 text-gray-600 text-xs text-center">{{this.date}}</td>
                        <td class="py-1 px-1 text-gray-800 text-[10px] text-center">{{this.description}}</td>
                        <td class="py-1 px-0.5 text-gray-800 text-center text-xs">{{this.count}}</td>
                        <td class="py-1 px-0.5 font-mono font-bold text-gray-800 text-xs text-center">{{this.credit}}
                        </td>
                        <td class="py-1 px-0.5 font-mono font-bold text-gray-800 text-xs text-center">{{this.debit}}
                        </td>
                        <td class="py-1 px-0.5 font-mono font-extrabold text-gray-800 bg-slate-100 text-xs text-center">
                            {{this.balance}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>

        <!-- Summary Boxes -->
        <div class="grid grid-cols-3 gap-4 mb-6 mt-5">
            <div class="bg-white p-4 rounded-md border border-gray-200 text-center">
                <span class="block text-xs text-gray-500 mb-1 opacity-80">إجمالي الدائن</span>
                <span class="block text-lg font-bold font-mono text-blue-600">{{summary.totalCredit}}</span>
            </div>
            <div class="bg-white p-4 rounded-md border border-gray-200 text-center">
                <span class="block text-xs text-gray-500 mb-1 opacity-80">إجمالي المدين</span>
                <span class="block text-lg font-bold font-mono text-blue-600">{{summary.totalDebit}}</span>
            </div>
            <div class="p-4 rounded-md text-center border bg-red-50 border-red-200">
                <span class="block text-xs opacity-80 mb-1 text-gray-700">الرصيد النهائي المستحق</span>
                <span class="block text-lg font-bold font-mono text-red-600">{{summary.finalBalance}} SAR</span>
            </div>
        </div>

        <!-- Amount in Words -->
        <div class="flex items-center bg-slate-100 p-3 rounded border-r-4 border-blue-900 mb-10 text-sm">
            <strong class="text-blue-900 ml-2">صافي الرصيد كتابة:</strong>
            <span>{{balanceInWords}}</span>
        </div>

        <!-- Footer / Signatures -->
        <footer class="flex justify-between items-end pt-5 border-t border-gray-200 mt-auto">
            <div class="text-center w-40">
                <p class="font-bold text-gray-600 text-sm mb-12">المحاسب</p>
                <div class="border-b border-dashed border-gray-400 w-full"></div>
            </div>
            <div class="text-center w-40">
                <p class="font-bold text-gray-600 text-sm mb-12">المدير المالي</p>
                <div class="border-b border-dashed border-gray-400 w-full"></div>
            </div>
            <div class="text-center w-40">
                <p class="font-bold text-gray-600 text-sm mb-12">مصادقة الوكيل الملاحي</p>
                <div class="border-b border-dashed border-gray-400 w-full"></div>
            </div>
        </footer>
    </div>
</body>

</html>