<!DOCTYPE html>
<html dir="rtl" lang="ar">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>التقرير الجمركي</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        * {
            font-family: 'Tajawal', sans-serif;
        }

        @page {
            size: A4;
            margin: 0;
        }

        body {
            margin: 0;
            padding: 0;
        }

        .print-content {
            width: 210mm;
            min-height: 297mm;
            padding: 10mm;
            background: white;
        }
    </style>
</head>

<body class="bg-white">
    <div class="print-content">
        <!-- Title -->
        <div class="text-center mb-6">
            <h2 class="text-2xl font-bold text-blue-900">التقرير الجمركي</h2>
            <p class="text-sm text-gray-600 mt-1">من {{startDate}} إلى {{endDate}}</p>
            <p class="text-sm text-gray-600">أنواع الفواتير: {{selectedTypesText}}</p>
        </div>

        <!-- Summary Cards -->
        <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="bg-blue-50 border-2 border-blue-600 rounded-lg p-4 text-center">
                <p class="text-sm text-blue-900 mb-1">عدد الفواتير</p>
                <p class="text-3xl font-bold text-blue-600">{{totalCount}}</p>
            </div>
            <div class="bg-green-50 border-2 border-green-600 rounded-lg p-4 text-center">
                <p class="text-sm text-green-900 mb-1">إجمالي المبلغ</p>
                <p class="text-3xl font-bold text-green-600">{{totalAmount}}</p>
            </div>
        </div>

        <!-- Invoices Table -->
        <div class="mb-6">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="bg-blue-900 text-white">
                        <th class="border border-blue-900 px-3 py-2 text-sm font-bold text-center">التاريخ</th>
                        <th class="border border-blue-900 px-3 py-2 text-sm font-bold text-center">العميل</th>
                        <th class="border border-blue-900 px-3 py-2 text-sm font-bold text-center">رقم البيان</th>
                        <th class="border border-blue-900 px-3 py-2 text-sm font-bold text-center">النوع</th>
                        <th class="border border-blue-900 px-3 py-2 text-sm font-bold text-center">المبلغ</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each invoices}}
                    <tr class="hover:bg-gray-50">
                        <td class="border border-gray-300 px-3 py-2 text-sm text-center">{{this.date}}</td>
                        <td class="border border-gray-300 px-3 py-2 text-sm">{{this.customerName}}</td>
                        <td class="border border-gray-300 px-3 py-2 text-sm text-center">{{this.declarationNo}}</td>
                        <td class="border border-gray-300 px-3 py-2 text-sm text-center">
                            <span
                                class="px-2 py-1 rounded text-xs font-medium bg-blue-100 text-blue-800">{{this.typeLabel}}</span>
                        </td>
                        <td class="border border-gray-300 px-3 py-2 text-sm text-center font-bold">{{this.total}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</body>

</html>